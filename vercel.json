{
  "version": 2,
  "env": {
    "DB_TYPE": "@db_type",
    "DB_HOST": "@db_host",
    "DB_USER": "@db_user",
    "DB_PASS": "@db_pass",
    "DB_NAME": "@db_name",
    "DB_PORT": "3306",
    "APP_URL": "@app_url",
    "APP_ENV": "production"
  },
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.6.4",
      "memory": 512,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "^/images/(.*)$",
      "dest": "/images/$1",
      "headers": {"Cache-Control": "public, max-age=86400"}
    },
    {
      "src": "^/fonts/(.*)$",
      "dest": "/fonts/$1",
      "headers": {"Cache-Control": "public, max-age=86400"}
    },
    {
      "src": "^/(.+\\.js)$",
      "dest": "/$1",
      "headers": {"Cache-Control": "public, max-age=3600"}
    },
    {
      "src": "^/(.+\\.css)$",
      "dest": "/$1",
      "headers": {"Cache-Control": "public, max-age=3600"}
    },
    {
      "src": "^/(.+\\.mp4)$",
      "dest": "/$1",
      "headers": {"Cache-Control": "public, max-age=604800"}
    },
    {
      "src": "^/api/(.*)$",
      "dest": "/api/$1.php"
    },
    {
      "src": "^/landing/?$",
      "dest": "/landing.php"
    },
    {
      "src": "^/auth/?$",
      "dest": "/auth.php"
    },
    {
      "src": "^/license.*/?$",
      "dest": "/license_gate.php"
    },
    {
      "src": "^/paypal.*/?$",
      "dest": "/paypal_return.php"
    },
    {
      "src": "^/inventory/(.*)$",
      "dest": "/inventory/$1.php"
    },
    {
      "src": "^/maintenance/(.*)$",
      "dest": "/maintenance/$1.php"
    },
    {
      "src": "^/reports/(.*)$",
      "dest": "/reports/$1.php"
    },
    {
      "src": "^/work_orders/(.*)$",
      "dest": "/work_orders/$1.php"
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.php?path=$1"
    }
  ]
}
