STRIPE_CANCEL_URL=https://your-cmms-domain.com/license_gate.php
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
APP_URL=https://your-cmms-domain.com
APP_SECRET=replace-with-a-long-random-secret
FORCE_HTTPS=true
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict
SECURITY_FRAME_OPTIONS=SAMEORIGIN
APP_ENV=production
ENABLE_DEBUG_PAGES=false
DB_TYPE=sqlite
DB_FILE=./database/maintenix.db

// ============================================================================
// LOGGING & MONITORING
// ============================================================================

// Log Levels: DEBUG, INFO, WARN, ERROR, FATAL
LOG_LEVEL=INFO
LOG_FILE=/var/log/cmms/integration.log
LOG_MAX_SIZE_MB=100  // Rotate when file exceeds this size

// API Request Logging
API_LOG_REQUESTS=true
API_LOG_RESPONSE_TIME=true
API_LOG_PAYLOADS=false  // Set to false in production for privacy

// ERP Sync Logging (stores in database)
ERP_LOG_SYNC_OPERATIONS=true
ERP_LOG_LEVEL=INFO

// Monitoring & Alerts
MONITORING_ENABLED=false
MONITORING_EMAIL=admin@example.com
ALERT_ON_SYNC_FAILURE=true
ALERT_ON_API_ERROR_RATE=true  // Alert if error rate exceeds threshold

// ============================================================================
// EMAIL CONFIGURATION (for alerts & notifications)
// ============================================================================

// SMTP Server
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password  // Use app-specific password, not account password
MAIL_ENCRYPTION=tls

// Email Settings
MAIL_FROM_ADDRESS=noreply@your-cmms.com
MAIL_FROM_NAME=CMMS Integration
MAIL_REPLY_TO=support@your-cmms.com

// Alert Recipients
MAIL_ALERT_TO=itsupport@your-company.com
MAIL_ERROR_BATCH_HOUR=8  // Send error summary email at 8 AM

// ============================================================================
// SECURITY CONFIGURATION
// ============================================================================

// API Security
API_REQUIRE_HTTPS=true
API_ALLOWED_IPS=*  // Set to specific IPs in production: 192.168.1.100,10.0.0.5

// SSL/TLS Certificate (if self-signed)
SSL_VERIFY_PEER=true
SSL_CERTIFICATE_PATH=/etc/ssl/certs/ca-bundle.crt

// API Key Rotation
API_KEY_ROTATION_ENABLED=false
API_KEY_ROTATION_DAYS=90

// ============================================================================
// INTEGRATION FEATURES (Enable/Disable)
// ============================================================================

// ERP Integrations
FEATURE_SAP_INTEGRATION=true
FEATURE_NETSUITE_INTEGRATION=true
FEATURE_ORACLE_INTEGRATION=false  // Future

// Cloud Storage
FEATURE_AWS_S3=true
FEATURE_GOOGLE_DRIVE=false
FEATURE_AZURE_BLOB=false

// GL Integration
FEATURE_GL_AUTO_POSTING=false
FEATURE_GL_COST_ALLOCATION=true

// API Endpoints
FEATURE_API_WORK_ORDERS=true
FEATURE_API_EQUIPMENT=true
FEATURE_API_INVENTORY=true
FEATURE_API_MAINTENANCE=true
FEATURE_API_USERS=false

// ============================================================================
// DEVELOPMENT & TESTING
// ============================================================================

// Environment
APP_ENV=production  // production, staging, development
APP_DEBUG=false     // Set to true only for development

// Testing Mode (when true, syncs are logged but not executed)
TEST_MODE=false
TEST_MODE_SAP=false

// ============================================================================
// KFMMS APPLICATION SETTINGS
// ============================================================================

DB_TYPE=sqlite
DB_HOST=127.0.0.1
