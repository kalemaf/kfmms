NETSUITE_CUSTOM_FIELD_CMMS_STATUS=custfield_123457
NETSUITE_CUSTOM_FIELD_CMMS_PRIORITY=custfield_123458

// GL Account mapping
NETSUITE_GL_LABOR_ACCOUNT=61000
NETSUITE_GL_PAYABLE_ACCOUNT=21000

// Sync configuration
NETSUITE_SYNC_ENABLED=true
NETSUITE_SYNC_ON_WO_COMPLETE=true
NETSUITE_SYNC_RETRY_ATTEMPTS=3
NETSUITE_SYNC_TIMEOUT_SECONDS=30

// ============================================================================
// AWS S3 CLOUD STORAGE CONFIGURATION
// ============================================================================

AWS_ENABLED=true

// AWS Account Credentials
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=wJal...

// S3 Bucket Configuration
AWS_BUCKET=cmms-production
AWS_REGION=us-east-1
