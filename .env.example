*/

// ============================================================================
// LOADING THIS CONFIGURATION
// ============================================================================

/*
In your code, load environment variables like this:

// Option 1: Load from .env file (using vlucas/phpdotenv)
$dotenv = new \Dotenv\Dotenv(__DIR__);
$dotenv->load();

// Option 2: Load from parse_ini_file
$env = parse_ini_file('.env');

// Option 3: Use $_ENV directly (from server configuration)
$sap_host = $_ENV['SAP_HOST'] ?? null;

// Option 4: Create as PHP constants
define('SAP_HOST', $_ENV['SAP_HOST']);
define('API_RATE_LIMIT', intval($_ENV['API_RATE_LIMIT'] ?? 1000));

// Then use:
$sap_config = [
    'host' => $_ENV['SAP_HOST'],
    'username' => $_ENV['SAP_USERNAME'],
    'password' => $_ENV['SAP_PASSWORD']
];

$sap = new SAPConnector($c, $sap_config);
*/

