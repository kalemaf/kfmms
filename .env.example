SMTP_FROM_NAME=Maintenix

DEBUG_MODE=false
DISPLAY_ERRORS=false
DEVELOPER_BYPASS_LICENSE=false
PERMISSION_REQUEST_NOTIFY_EMAIL=kalemaf876@gmail.com
TEST_MODE_NETSUITE=false
TEST_MODE_CLOUD_STORAGE=false

// API Documentation
API_DOCUMENTATION_ENABLED=true
API_SWAGGER_ENABLED=true
SWAGGER_PATH=/api/swagger/

// ============================================================================
// TIMEZONE & LOCALIZATION
// ============================================================================

APP_TIMEZONE=America/New_York
APP_LOCALE=en_US
DATE_FORMAT=Y-m-d
TIME_FORMAT=H:i:s
CURRENCY=USD

// ============================================================================
// PERFORMANCE TUNING
// ============================================================================

// Cache Configuration
CACHE_DRIVER=file  // file, redis, memcache
CACHE_TTL_HOURS=24

// Database Query Optimization
QUERY_TIMEOUT_SECONDS=30
SLOW_QUERY_LOG_ENABLED=true
SLOW_QUERY_THRESHOLD_MS=1000

// API Response Compression
API_GZIP_COMPRESSION=true

// ============================================================================
// WEBHOOK CONFIGURATION (for external system callbacks)
// ============================================================================

WEBHOOK_ENABLED=false
WEBHOOK_SECRET=your-webhook-secret-key
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY_SECONDS=60

// External System Webhooks (if they call us)
WEBHOOK_SAP_NOTIFICATION_URL=https://your-cmms.com/api/webhooks/sap
WEBHOOK_NETSUITE_NOTIFICATION_URL=https://your-cmms.com/api/webhooks/netsuite

// ============================================================================
// BACKUP & DISASTER RECOVERY
// ============================================================================

BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  // 2 AM daily
BACKUP_RETENTION_DAYS=30
BACKUP_LOCATION=/var/backups/cmms
BACKUP_CLOUD_STORAGE=s3  // s3, google, azure, none

// ============================================================================
// FILE UPLOAD RESTRICTIONS
// ============================================================================

FILE_UPLOAD_MAX_SIZE_MB=100
FILE_UPLOAD_ALLOWED_TYPES=pdf,png,jpg,jpeg,doc,docx,xls,xlsx,txt,zip
FILE_UPLOAD_SCAN_FOR_VIRUS=false  // Requires ClamAV

// ============================================================================
// RATE LIMITING BY ENDPOINT
// ============================================================================

// Format: ENDPOINT_PATH=requests_per_minute
API_RATE_LIMIT_DEFAULT=60
API_RATE_LIMIT_LOGIN=5
API_RATE_LIMIT_API_KEY_GENERATION=1
API_RATE_LIMIT_SYNC_ENDPOINTS=10

// ============================================================================
// EXAMPLE VALUES REFERENCE
// ============================================================================

