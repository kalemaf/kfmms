#!/usr/bin/env php
<?php
/**
 * INTEGRATION CONFIGURATION TEMPLATE
 * 
 * Copy this file to .env or source these values from environment
 * DO NOT commit credentials to version control!
 * 
 * Usage:
 * 1. Copy this file to .env.example
 * 2. Create .env with your actual values
 * 3. Load: $env = parse_ini_file('.env');
 *    OR use: $_ENV variables from server configuration
 */

// ============================================================================
// API CONFIGURATION
// ============================================================================

// API server settings
API_HOST=http://localhost
API_PORT=80
API_PROTOCOL=http

// Rate limiting (requests per hour per client)
API_RATE_LIMIT=1000

// JWT/Bearer token configuration
API_TOKEN_EXPIRATION_DAYS=365
API_TOKEN_SECRET=your-super-secret-random-string-min-32-chars-xyzabc123

// CORS Origins (comma-separated domains allowed to call your API)
API_CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com,http://localhost:3000

// ============================================================================
// SAP ERP CONFIGURATION
// ============================================================================

// Connection settings
SAP_HOST=https://sap.example.com
SAP_PORT=443
SAP_PATH=/sap/opu/odata/sap

// Authentication
SAP_USERNAME=cmms_api_user
SAP_PASSWORD=your-sap-password-here
SAP_CLIENT=100

// Business configuration
SAP_COMPANY_CODE=US01
SAP_CONTROLLING_AREA=CA01
SAP_COST_CENTER=MAINT01
SAP_BUSINESS_UNIT=BU01

// OData Service versions
SAP_SERVICE_VERSION=4.0

// GL Account mapping (for maintenance transactions)
SAP_GL_LABOR_ACCOUNT=61000
SAP_GL_PARTS_ACCOUNT=61500
SAP_GL_PAYABLE_ACCOUNT=21000

// Sync configuration
SAP_SYNC_ENABLED=true
SAP_SYNC_ON_WO_COMPLETE=true
SAP_SYNC_RETRY_ATTEMPTS=3
SAP_SYNC_TIMEOUT_SECONDS=30

// ============================================================================
// NETSUITE ERP CONFIGURATION
// ============================================================================

// NetSuite Account Information
