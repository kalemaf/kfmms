GOOGLE_REDIRECT_URI=https://your-cmms.com/api/oauth/google_callback

// OAuth Tokens (obtained after first authorization)
GOOGLE_ACCESS_TOKEN=ya29.xxx
GOOGLE_REFRESH_TOKEN=1//xxx

// Google Drive Folder Configuration
GOOGLE_DRIVE_FOLDER_ID=root
GOOGLE_DRIVE_FOLDER_NAME=CMMS_Work_Orders

// ============================================================================
// AZURE BLOB STORAGE CONFIGURATION
// ============================================================================

AZURE_ENABLED=false

// Azure Storage Account Credentials
AZURE_ACCOUNT_NAME=cmmsaccount
AZURE_ACCOUNT_KEY=DefaultEndpointsProtocol=https;AccountName=...

// Azure Container Configuration
AZURE_CONTAINER=work-orders
AZURE_STORAGE_TIER=Hot

// ============================================================================
// GL (GENERAL LEDGER) ACCOUNTING CONFIGURATION
// ============================================================================

// GL Posting Settings
GL_AUTO_POST_ON_WO_COMPLETE=false  // Set to true to auto-post GL entries
GL_REQUIRE_APPROVAL=true            // Require manual approval before posting
GL_APPROVAL_TIMEOUT_DAYS=5          // Auto-approve after N days if not reviewed

// Default GL Accounts
GL_DEFAULT_DEBIT_ACCOUNT=61000      // Maintenance Labor
GL_DEFAULT_CREDIT_ACCOUNT=21000     // Accrued Payables
GL_DEFAULT_COST_CENTER=MAINT

// GL Account Structure (customize to match your chart of accounts)
