// OAuth 2.0 Credentials
NETSUITE_CLIENT_ID=your-netsuite-oauth-client-id
NETSUITE_CLIENT_SECRET=your-netsuite-oauth-client-secret
NETSUITE_REFRESH_TOKEN=your-netsuite-refresh-token
NETSUITE_REDIRECT_URI=https://your-cmms.com/api/oauth/netsuite_callback

// NetSuite Business Configuration
NETSUITE_SUBSIDIARY_ID=1
NETSUITE_DEPARTMENT_ID=1

// Custom field IDs (obtained from NetSuite customization)
