GL_MAINTENANCE_PARTS_ACCOUNT=61500
GL_MAINTENANCE_MISC_ACCOUNT=61600
GL_MAINTENANCE_SUBCONTRACTOR_ACCOUNT=61700
GL_PAYABLE_ACCOUNT=21000
GL_PAYROLL_LIABILITY_ACCOUNT=21100

// Equipment-specific GL Accounts (optional, overrides defaults)
