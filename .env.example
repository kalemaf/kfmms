GL_MOTOR_ACCOUNT=61210
GL_COMPRESSOR_ACCOUNT=61220
GL_CHILLER_ACCOUNT=61230
GL_HVAC_ACCOUNT=61240
GL_ELECTRICAL_ACCOUNT=61250

